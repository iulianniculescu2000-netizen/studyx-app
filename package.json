{
  "name": "studyx",
  "productName": "StudyX",
  "private": true,
  "version": "1.0.8",
  "type": "module",
  "description": "Aplicatie de grile pentru studenti la medicina",
  "author": "StudyX",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "generate-icon": "node scripts/generate-premium-assets.cjs",
    "prepare-update": "npm run build && node scripts/prepare-update.cjs",
    "electron:dev": "cross-env.cmd NODE_ENV=development concurrently.cmd \"vite.cmd\" \"wait-on.cmd http://localhost:5173 && electron.cmd .\"",
    "electron:build": "npm run generate-icon && npm run build && electron-builder.cmd",
    "electron:build:dir": "npm run generate-icon && npm run build && electron-builder.cmd --dir"
  },
  "build": {
    "electronVersion": "41.0.3",
    "appId": "com.studyx.medical",
    "productName": "StudyX",
    "copyright": "Copyright © 2025 StudyX",
    "asar": true,
    "compression": "maximum",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/icon.png",
      "package.json",
      "!**/*.map",
      "!**/*.ts",
      "node_modules/pdf-parse/**/*",
      "!node_modules/pdf-parse/test/**/*"
    ],
    "win": {
      "icon": "public/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "forceCodeSigning": false,
      "signAndEditExecutable": false,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "StudyX",
      "menuCategory": "StudyX",
      "deleteAppDataOnUninstall": true,
      "include": "build/installer.nsh",
      "license": "LICENSE.txt",
      "runAfterFinish": true,
      "installerSidebar": "build/sidebar.bmp",
      "installerHeader": "build/header.bmp"
    }
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@types/canvas-confetti": "^1.9.0",
    "canvas-confetti": "^1.9.4",
    "framer-motion": "^12.38.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.577.0",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0",
    "tesseract.js": "^6.0.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "electron-winstaller": "^5.4.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "wait-on": "^9.0.4"
  }
}
