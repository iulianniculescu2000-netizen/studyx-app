{
  "name": "studyx",
  "productName": "StudyX",
  "private": true,
  "version": "1.0.5",
  "type": "module",
  "description": "Aplicatie de grile pentru studenti la medicina",
  "author": "StudyX",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "dist": "npm run electron:build",
    "generate-icon": "node scripts/generate-premium-assets.cjs",
    "prepare-update": "npm run build && node scripts/prepare-update.cjs",
    "publish-update": "node scripts/publish-update.cjs",
    "electron:dev": "cross-env.cmd NODE_ENV=development concurrently.cmd \"vite.cmd\" \"wait-on.cmd http://localhost:5173 && electron.cmd .\"",
    "electron:build": "npm run generate-icon && npm run build && electron-builder.cmd",
    "electron:build:dir": "npm run generate-icon && npm run build && electron-builder.cmd --dir",
    "electron:publish": "node scripts/publish-release.cjs"
  },
  "build": {
    "appId": "com.studyx.app",
    "productName": "StudyX",
    "asar": true,
    "asarUnpack": [
      "**/*.node",
      "node_modules/@napi-rs/**/*",
      "node_modules/pdf-parse/**/*",
      "node_modules/pdfjs-dist/**/*",
      "node_modules/tesseract.js/**/*"
    ],
    "compression": "maximum",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico",
      "forceCodeSigning": false,
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "StudyX",
      "artifactName": "StudyX-Setup-${version}.${ext}",
      "menuCategory": "StudyX",
      "deleteAppDataOnUninstall": false,
      "include": "build/installer.nsh",
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico",
      "installerHeaderIcon": "public/icon.ico",
      "installerSidebar": "build/sidebar.bmp",
      "uninstallerSidebar": "build/sidebar.bmp",
      "installerHeader": "build/header.bmp"
    },
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/icon.ico",
      "public/icon.png",
      "public/icon.svg",
      "package.json",
      "!**/*.map",
      "!**/*.ts",
      "!**/*.tsx",
      "!**/.git/**",
      "!**/.claude/**",
      "!studyx-updates{,/**}",
      "!studyx-updates-temp{,/**}",
      "!release{,/**}",
      "!Chestii utile{,/**}",
      "!Grile{,/**}",
      "!SABLON{,/**}",
      "!*.docx",
      "!*.png",
      "!.env*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "iulianniculescu2000-netizen",
        "repo": "studyx-updates",
        "releaseType": "release"
      }
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@types/canvas-confetti": "^1.9.0",
    "canvas-confetti": "^1.9.4",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.38.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.577.0",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0",
    "tesseract.js": "^6.0.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "electron-winstaller": "^5.4.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "wait-on": "^9.0.4"
  }
}
